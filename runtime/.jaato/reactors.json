{
  "version": 1,
  "rules": [
    {
      "id": "curate-memories-on-complete",
      "enabled": true,
      "match": {
        "event_type": "agent.completed",
        "where": "source_agent == 'telegram_chat'"
      },
      "action": {
        "script": "reactors/on_memory_curate.py",
        "params": {}
      }
    }
  ]
}
