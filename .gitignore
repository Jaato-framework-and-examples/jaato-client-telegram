# Project-specific
*.yaml
!config.example.yaml
# The live config holds NO literal secrets (bot_token/secret_token are ${ENV}
# substitutions) — only host-specific absolute paths — so it is tracked.
!jaato-client-telegram.yaml
*.sock
# bot runtime workspace (jaato_ws.workspace = ./runtime): the bot runs each chat
# session inside ./runtime, so ALL runtime state (sessions, logs, memories,
# vision, instructions, backups, zhipuai_auth) AND the agent's own file outputs
# (tool_drafts/, scratch files) land here and are ignored. Only the versioned
# profile + agent persona under runtime/.jaato/ are tracked. Negations come after
# *.yaml above so they win for the profile yaml.
runtime/*
!runtime/.jaato/
runtime/.jaato/*
!runtime/.jaato/profiles/
!runtime/.jaato/profiles/**
!runtime/.jaato/agents/
!runtime/.jaato/agents/**
# prefetch scripts are code referenced by the tracked personas (e.g. a mandatory
# {{!py:scripts/...}} directive) — they must travel with the agent definition.
# (service_manifest.json stays ignored: it's mutable runtime state, host-tool-managed.)
!runtime/.jaato/scripts/
!runtime/.jaato/scripts/**
runtime/.jaato/scripts/**/__pycache__/

# User data and workspaces
workspaces/
whitelist.json

